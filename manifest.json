{
  "manifest_version": 3,
  "name": "Vocab Saver",
  "version": "1.0",
  "description": "드래그한 영어 텍스트를 번역하고 단어장을 Google Sheets에 저장합니다.",
  "permissions": [
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://translation.googleapis.com/*",
    "https://sheets.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "options_page": "options.html",
  "oauth2": {
    "client_id": "737109337849-603p6ks9gaa39ekgb11caore95hg3i1h.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/spreadsheets"]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Vocab Saver",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["content.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
